{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/goodbye-jack/go-common/configspec/schema/config-spec.schema.json",
  "title": "go-common config spec module",
  "type": "object",
  "required": [
    "module",
    "title",
    "description",
    "owner",
    "order",
    "items"
  ],
  "properties": {
    "module": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "order": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": [
        "key",
        "kind",
        "since",
        "comment"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "object",
            "scalar",
            "map",
            "list"
          ]
        },
        "type": {
          "type": "string"
        },
        "since": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "comment": {
          "type": "string",
          "minLength": 1
        },
        "example": {},
        "default": {},
        "required": {
          "type": "boolean"
        },
        "group": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "enum": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sensitive": {
          "type": "boolean"
        },
        "compatibility_only": {
          "type": "boolean"
        },
        "merge_policy": {
          "type": "string"
        },
        "required_when": {
          "type": "object"
        },
        "activation": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
